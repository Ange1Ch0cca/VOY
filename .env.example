# ============================================
# VOY - ENVIRONMENT CONFIGURATION
# Example file (DO NOT include real credentials)
# Copyright © 2026 UNIT. All Rights Reserved.
# ============================================

# ============================================
# APPLICATION
# ============================================

APP_NAME=VOY
APP_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
APP_DEBUG=true

# ============================================
# DATABASE
# ============================================

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=voy_db
DB_USER=postgres
DB_PASSWORD=

# ============================================
# AUTHENTICATION (JWT)
# ============================================

JWT_SECRET=
JWT_EXPIRES_IN=7d

# ============================================
# SECURITY
# ============================================

BCRYPT_SALT_ROUNDS=10

# ============================================
# REAL TIME (future WebSockets)
# ============================================

SOCKET_PORT=4000

# ============================================
# FILE STORAGE
# ============================================

STORAGE_PROVIDER=local
STORAGE_PATH=./storage

# ============================================
# MAPS / LOCATION SERVICES
# ============================================

GOOGLE_MAPS_API_KEY=

# ============================================
# PAYMENTS
# ============================================

STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=

# ============================================
# EMAIL SERVICE
# ============================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@voy.unit.pe

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=debug